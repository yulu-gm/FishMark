{
  "appId": "com.yulora.app",
  "afterPack": "./scripts/after-pack-win-icon.mjs",
  "productName": "Yulora",
  "artifactName": "${productName}-Setup-${version}.${ext}",
  "directories": {
    "output": "release"
  },
  "files": [
    "package.json",
    "dist/**/*",
    "dist-electron/**/*",
    "dist-cli/**/*",
    "!src{,/**}",
    "!tests{,/**}",
    "!docs{,/**}",
    "!reports{,/**}",
    "!.artifacts{,/**}",
    "!fixtures{,/**}",
    "!tmp{,/**}"
  ],
  "win": {
    "icon": "build/icons/light/icon.ico",
    "signAndEditExecutable": false,
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
